COMPOSE_PROJECT_NAME=timbre

# ────────────────────────────────────────────────────────────────────────────
# Postgres (interno, no expuesto)
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=atrium_calls
POSTGRES_USER=atrium
POSTGRES_PASSWORD=change-me
# Importante: la password debe coincidir con POSTGRES_PASSWORD de arriba.
DATABASE_URL=postgres://atrium:change-me@postgres:5432/atrium_calls?sslmode=disable

REDIS_URL=redis://redis:6379/0

# ────────────────────────────────────────────────────────────────────────────
# Arquitectura de red
# ────────────────────────────────────────────────────────────────────────────
# El único servicio expuesto públicamente es `frontend`. Backend, voice-agent
# y minio viven en la red Docker interna y se acceden vía Next rewrites
# (/api/* → backend, /storage/* → minio). En Coolify asigna dominio solo al
# servicio `frontend`. No hace falta `NEXT_PUBLIC_API_URL`.
# ────────────────────────────────────────────────────────────────────────────
BACKEND_INTERNAL_URL=http://backend:8080
MINIO_INTERNAL_URL=http://minio:9000

# CORS permitido por el backend. Mismo-origen no necesita CORS, así que en
# producción puede quedar vacío. Solo hace falta si llamas al backend
# directamente desde otro host (dev local con frontend separado).
ALLOWED_ORIGINS=

# ────────────────────────────────────────────────────────────────────────────
# Secretos críticos. TODOS son OBLIGATORIOS — el backend rechaza arrancar si
# falta cualquiera de los tres.
# ────────────────────────────────────────────────────────────────────────────

# JWT de la API. Cualquier cadena larga aleatoria.
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string
JWT_TTL=12h

# Auth entre backend ↔ voice-agent (endpoints /api/internal/voice/*).
# Sin este secret cualquiera con acceso a la red Docker interna podría
# enviar transcripts/recordings falsos. OBLIGATORIO.
#   openssl rand -base64 32
VOICE_AGENT_SHARED_SECRET=

# Master key para cifrar API keys de proveedores de voz (OpenAI/Deepgram/
# AssemblyAI) en Postgres. 32 bytes base64. Si la rotas, las keys ya
# guardadas dejan de ser legibles y el operador tiene que volver a
# meterlas desde /portal/settings. OBLIGATORIO.
#   openssl rand -base64 32
SECRETS_MASTER_KEY=

# Usuarios bootstrap (solo se crean si no existe ningún usuario aún).
BOOTSTRAP_ADMIN_EMAIL=admin@timbre.ai
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_TENANT_EMAIL=owner@atrium.local
BOOTSTRAP_TENANT_PASSWORD=change-me
BOOTSTRAP_TENANT_ID=atrium

# ────────────────────────────────────────────────────────────────────────────
# Asterisk + ARI
# ────────────────────────────────────────────────────────────────────────────
ASTERISK_ARI_ENABLED=false
ASTERISK_ARI_URL=http://asterisk:8088/ari
ASTERISK_ARI_USER=timbre
ASTERISK_ARI_PASSWORD=change-me
ASTERISK_ARI_APP=timbre-bot
ASTERISK_HTTP_PORT=8088

# Puertos del trunk SIP (proveedor externo).
ASTERISK_SIP_PORT=5060
ASTERISK_RTP_START=10000
ASTERISK_RTP_END=10020

# Sandbox: cuando se origina una test call sin elegir bot, va aquí.
SIP_TEST_EXTENSION=PJSIP/6001
SIP_CALLER_ID=timbre.ai <1000>

# RTP del External Media (Asterisk ↔ voice-agent dentro de la red Docker).
RTP_PORT_START=12000
RTP_PORT_END=12099
RTP_ADVERTISE_HOST=voice-agent

# ────────────────────────────────────────────────────────────────────────────
# Voice agent
# Las API keys de OpenAI / Deepgram / AssemblyAI NO viven aquí.
# Cada tenant las configura desde el portal en /portal/settings.
# ────────────────────────────────────────────────────────────────────────────
VOICE_AGENT_URL=http://voice-agent:8090
VOICE_AGENT_ALLOWED_ORIGINS=*

# ────────────────────────────────────────────────────────────────────────────
# Object storage (MinIO / S3) para grabaciones
# ────────────────────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=timbre
STORAGE_SECRET_KEY=timbre-secret-change-me
STORAGE_BUCKET=timbre-recordings
# Vacío = el backend devuelve URLs relativas "/storage/...". El frontend Next
# las proxea a MinIO por la red Docker — minio NO necesita dominio público.
# Solo seteado si usas S3 externo o quieres servir grabaciones desde un
# dominio dedicado (p.ej. https://storage.tudominio.com).
STORAGE_PUBLIC_URL=
