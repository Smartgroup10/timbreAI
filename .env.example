COMPOSE_PROJECT_NAME=timbre

# ────────────────────────────────────────────────────────────────────────────
# Postgres (interno, no expuesto)
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=atrium_calls
POSTGRES_USER=atrium
POSTGRES_PASSWORD=change-me
# Importante: la password debe coincidir con POSTGRES_PASSWORD de arriba.
DATABASE_URL=postgres://atrium:change-me@postgres:5432/atrium_calls?sslmode=disable

REDIS_URL=redis://redis:6379/0

# ────────────────────────────────────────────────────────────────────────────
# Puertos locales (solo afectan a `docker compose up` en tu máquina).
# En Coolify el routing público lo gestiona Traefik con los dominios que
# pongas en el panel — no se configura aquí.
# ────────────────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000
VOICE_AGENT_PORT=8091
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# URL pública del backend tal y como la verá el navegador del cliente.
# El frontend bakea esta URL en build time, así que tiene que apuntar al host
# definitivo cuando despliegues (p.ej. https://api.tudominio.com).
NEXT_PUBLIC_API_URL=http://localhost:8080

# CORS permitido por el backend.
ALLOWED_ORIGINS=http://localhost:3000

# ────────────────────────────────────────────────────────────────────────────
# Auth — JWT_SECRET DEBE ser una cadena larga aleatoria.
# Genera uno con: openssl rand -base64 48
# ────────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_TTL=12h

# Secreto compartido entre backend y voice-agent.
# Genera uno con: openssl rand -base64 32
VOICE_AGENT_SHARED_SECRET=

# Usuarios bootstrap (solo se crean si no existe ningún usuario aún).
BOOTSTRAP_ADMIN_EMAIL=admin@timbre.ai
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_TENANT_EMAIL=owner@atrium.local
BOOTSTRAP_TENANT_PASSWORD=change-me
BOOTSTRAP_TENANT_ID=atrium

# ────────────────────────────────────────────────────────────────────────────
# Asterisk + ARI
# ────────────────────────────────────────────────────────────────────────────
ASTERISK_ARI_ENABLED=false
ASTERISK_ARI_URL=http://asterisk:8088/ari
ASTERISK_ARI_USER=timbre
ASTERISK_ARI_PASSWORD=change-me
ASTERISK_ARI_APP=timbre-bot
ASTERISK_HTTP_PORT=8088

# Puertos del trunk SIP (proveedor externo).
ASTERISK_SIP_PORT=5060
ASTERISK_RTP_START=10000
ASTERISK_RTP_END=10020

# Sandbox: cuando se origina una test call sin elegir bot, va aquí.
SIP_TEST_EXTENSION=PJSIP/6001
SIP_CALLER_ID=timbre.ai <1000>

# RTP del External Media (Asterisk ↔ voice-agent dentro de la red Docker).
RTP_PORT_START=12000
RTP_PORT_END=12099
RTP_ADVERTISE_HOST=voice-agent

# ────────────────────────────────────────────────────────────────────────────
# Voice agent
# Las API keys de OpenAI / Deepgram / AssemblyAI NO viven aquí.
# Cada tenant las configura desde el portal en /portal/settings.
# ────────────────────────────────────────────────────────────────────────────
VOICE_AGENT_URL=http://voice-agent:8090
BACKEND_INTERNAL_URL=http://backend:8080
VOICE_AGENT_ALLOWED_ORIGINS=*

# ────────────────────────────────────────────────────────────────────────────
# Object storage (MinIO / S3) para grabaciones
# ────────────────────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=timbre
STORAGE_SECRET_KEY=timbre-secret-change-me
STORAGE_BUCKET=timbre-recordings
# URL pública desde donde el navegador descarga las grabaciones.
# En producción debe ser HTTPS (p.ej. https://storage.tudominio.com).
STORAGE_PUBLIC_URL=http://localhost:9000
