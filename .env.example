COMPOSE_PROJECT_NAME=timbre

# --- Postgres ---
# DB credentials are kept under the legacy "atrium" identifiers because the running stack was
# bootstrapped with them and they are not user-facing. Change them in your own .env if you wipe
# the volume.
POSTGRES_DB=timbre
POSTGRES_USER=timbre
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://timbre:change-me@postgres:5432/timbre?sslmode=disable

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API & Frontend ---
BACKEND_PORT=8080
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000

# Auth. JWT_SECRET MUST be set to a long random string (e.g. `openssl rand -base64 48`).
JWT_SECRET=replace-with-a-long-random-string
JWT_TTL=12h

# Bootstrap users created on first boot (only if no users exist yet).
BOOTSTRAP_ADMIN_EMAIL=admin@timbre.ai
BOOTSTRAP_ADMIN_PASSWORD=atrium123
BOOTSTRAP_TENANT_EMAIL=owner@atrium.local
BOOTSTRAP_TENANT_PASSWORD=atrium123
BOOTSTRAP_TENANT_ID=atrium

# --- Asterisk / ARI ---
ASTERISK_ARI_ENABLED=false
ASTERISK_ARI_URL=http://asterisk:8088/ari
ASTERISK_ARI_USER=timbre
ASTERISK_ARI_PASSWORD=change-me
ASTERISK_ARI_APP=timbre-bot
ASTERISK_HTTP_PORT=8088
ASTERISK_SIP_PORT=5060
ASTERISK_RTP_START=10000
ASTERISK_RTP_END=10020

# Sandbox fallback when no bot is selected for a test call. Real trunks are configured from the
# admin UI (/admin/trunks) and stored in Postgres; they reference PJSIP endpoints defined in
# asterisk/etc/asterisk/pjsip.conf by name.
SIP_TEST_EXTENSION=PJSIP/6001
SIP_CALLER_ID=timbre.ai <1000>

# --- Production routing (Coolify / Traefik) ---
# Set TRAEFIK_ENABLE=true and configure these hostnames to expose the platform via Traefik.
# Coolify provisions Let's Encrypt certs automatically when the labels match its setup.
TRAEFIK_ENABLE=false
FRONTEND_HOST=portal.example.com
BACKEND_HOST=api.example.com
VOICE_AGENT_HOST=voice.example.com
MINIO_HOST=storage.example.com

# --- Voice agent ---
# The voice-agent service drives realtime conversations (ASR + LLM + TTS). Each bot picks a
# provider; if no API key is configured for a given provider, that bot will fail to start a
# session and only the `echo` provider will work (useful for plumbing tests).
VOICE_AGENT_PORT=8091
VOICE_AGENT_URL=http://voice-agent:8090
VOICE_AGENT_SHARED_SECRET=
VOICE_AGENT_ALLOWED_ORIGINS=*

# RTP transport for Asterisk External Media. The advertised host must be reachable from inside
# the Asterisk container — by default "voice-agent" works in Docker compose. In Coolify with a
# split host, set RTP_ADVERTISE_HOST to the public IP/hostname that Asterisk can reach.
RTP_PORT_START=12000
RTP_PORT_END=12099
RTP_ADVERTISE_HOST=voice-agent

# Required by OpenAI Realtime provider AND used as default LLM/TTS for Deepgram/AssemblyAI pipelines.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_REALTIME_VOICE=alloy

# Deepgram Voice Agent (wss://agent.deepgram.com/v1/agent/converse) — single end-to-end socket.
# Platform-wide defaults; each tenant can override from /portal/settings.
DEEPGRAM_API_KEY=
DEEPGRAM_LISTEN_MODEL=nova-3
DEEPGRAM_THINK_PROVIDER=open_ai
DEEPGRAM_THINK_MODEL=gpt-4o-mini
DEEPGRAM_SPEAK_MODEL=aura-asteria-en
DEEPGRAM_GREETING=

# AssemblyAI Voice Agent (wss://agents.assemblyai.com/v1/ws) — single end-to-end socket.
# AssemblyAI hosts LLM + TTS internally; only voice and greeting are configurable.
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_VOICE=ivy
ASSEMBLYAI_GREETING=

# --- Object storage (MinIO / S3) for call recordings ---
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=timbre
STORAGE_SECRET_KEY=timbre-secret-change-me
STORAGE_BUCKET=timbre-recordings
STORAGE_PUBLIC_URL=http://localhost:9000

# --- Misc ---
PUBLIC_BASE_URL=https://calls.example.com
